{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "APPNAME",
  "main": "src/worker.ts",
  "compatibility_date": "2026-05-01",

  "assets": {
    "directory": "./web/dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },

  "durable_objects": {
    "bindings": [{ "name": "ROOM", "class_name": "RoomDO" }]
  },

  "migrations": [{ "tag": "v1", "new_sqlite_classes": ["RoomDO"] }]
}
